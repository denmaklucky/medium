@model HumanMadeApp.Pages.Components.ToDoList

<div>

    <div class="card mb-3 todo-list--new">
        <div class="card-body p-3">
            <p class="mb-2 todo-list--new-input">New item</p>
            <div class="d-flex gap-2">
                <input bind asp-for="NewItem" type="text" class="form-control form-control-sm" placeholder="What needs to be done?">
                <button class="btn btn-primary btn-sm px-3" on:click="@(() => Model.CreateAsync())">Add</button>
            </div>
        </div>
    </div>

    <div class="card mb-3 todo-list--active">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <p class="mb-0 todo-list--active-text">
                    Active <span class="badge bg-primary rounded-pill ms-1">@(Model.ActiveToDos?.Count ?? 0)</span>
                </p>
            </div>
            <ul class="list-group list-group-flush">
                @if (Model.ActiveToDos == null || Model.ActiveToDos.Count == 0)
                {
                    <li class="list-group-item text-muted todo-list--active-empty">No active items</li>
                }
            </ul>
        </div>
    </div>

    <div class="card todo-list--complete">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center">
                <p class="mb-0 todo-list--complete-text">
                    Completed <span class="badge bg-secondary rounded-pill ms-1" id="done-count">@(Model.CompletedToDosCount ?? 0)</span>
                </p>
                <button class="btn btn-sm btn-outline-secondary" on:click="@(() => Model.ToggleShowCompletedTodos())">Show</button>
            </div>
            <ul class="list-group list-group-flush mt-2" style="display: none;"></ul>
        </div>
    </div>

</div>
