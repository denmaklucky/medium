
@model HumanMadeApp.Pages.Components.ToDoList

<div>

    <div class="card mb-3" style="border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg);">
        <div class="card-body p-3">
            <p class="mb-2" style="font-size: 13px; font-weight: 500; color: var(--color-text-secondary);">New item</p>
            <div class="d-flex gap-2">
                <input type="text" id="todo-input" class="form-control form-control-sm" placeholder="What needs to be done?">
                <button class="btn btn-primary btn-sm px-3" onclick="addTodo()">Add</button>
            </div>
        </div>
    </div>

    <div class="card mb-3" style="border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg);">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <p class="mb-0" style="font-size: 13px; font-weight: 500; color: var(--color-text-secondary);">Active <span class="badge bg-primary rounded-pill ms-1" id="active-count">0</span></p>
            </div>
            <ul class="list-group list-group-flush" id="active-list">
                <li class="list-group-item text-muted" style="font-size: 13px; padding: 8px 0;" id="empty-msg">No active items</li>
            </ul>
        </div>
    </div>

    <div class="card" style="border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg);">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center">
                <p class="mb-0" style="font-size: 13px; font-weight: 500; color: var(--color-text-secondary);">
                    Completed <span class="badge bg-secondary rounded-pill ms-1" id="done-count">0</span>
                </p>
                <button class="btn btn-sm btn-outline-secondary" style="font-size: 12px; padding: 2px 10px;" onclick="toggleArchive()" id="archive-btn">Show</button>
            </div>
            <ul class="list-group list-group-flush mt-2" id="done-list" style="display: none;"></ul>
        </div>
    </div>

</div>
