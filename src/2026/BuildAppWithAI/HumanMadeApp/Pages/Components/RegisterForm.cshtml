@model HumanMadeApp.Pages.Components.RegisterForm

<div class="card register-form">
    <div class="card-body p-4">
        <h2 class="mb-1 fs-4 register-form--title">Create an account</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger register-form--error" role="alert">
                <strong>Error:</strong> <span id="error-message">@Model.ErrorMessage</span>
            </div>
        }

        <div class="mb-3">
            <label class="form-label register-form--label">Username</label>
            <input bind asp-for="Username" type="text" class="form-control form-control-sm" placeholder="Denis Makarenko">
        </div>

        <div class="mb-3">
            <label class="form-label register-form--label">Password</label>
            <input bind asp-for="Password" value="@Model.Password" type="@(Model.ShowPassword ? "text" : "password")" class="form-control form-control-sm" placeholder="Password">
        </div>

        <div class="mb-3">
            <label class="form-label register-form--label">Confirm password</label>
            <input bind asp-for="ConfirmPassword" value="@Model.ConfirmPassword" type="@(Model.ShowPassword ? "text" : "password")" class="form-control form-control-sm" placeholder="Repeat your password">
        </div>

        <div class="form-check mb-4">
            <input bind asp-for="ShowPassword" class="form-check-input" type="checkbox"/>
            <label class="form-check-label register-form--label">Show password</label>
        </div>

        <p class="text-muted mb-4 register-form--text">
            Already have one? <a class="text-decoration-none" href="#" on:click="@(() => Model.NavigateToSignIn())">Sign in</a>
        </p>

        <button class="btn btn-primary w-100 btn-sm register-form--register-button" on:click="@(() => Model.RegisterUserAsync())">Sign up</button>
    </div>
</div>
